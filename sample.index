<footer>
  <p>すべてのエフェクトは HTML / CSS / JavaScript のみで実装 — 外部画像・外部ライブラリ不使用</p>
  <p style="margin-top:0.4rem;font-size:0.7rem;color:#44446a">01 Glassmorphism &nbsp;·&nbsp; 02 Neon Glow &nbsp;·&nbsp; 03 CSS 3D &nbsp;·&nbsp; 04 Glitch &nbsp;·&nbsp; 05 Blob Morph &nbsp;·&nbsp; 06 Text FX &nbsp;·&nbsp; 07 Scroll Reveal &nbsp;·&nbsp; 08 Particles &nbsp;·&nbsp; 09 Holographic &nbsp;·&nbsp; 10 Noise Grain</p>
</footer>

<script>
/* ── AURORA BACKGROUND ───────────────────────── */
!function() {
  const c = document.getElementById('aurora-canvas');
  const ctx = c.getContext('2d');
  let t = 0;
  const resize = () => { c.width = c.offsetWidth; c.height = c.offsetHeight; };
  resize(); window.addEventListener('resize', resize);
  const orbs = [
    { px:0.2, py:0.35, r:0.5, col:[124,58,237] },
    { px:0.8, py:0.6,  r:0.4, col:[6,182,212]  },
    { px:0.5, py:0.8,  r:0.45,col:[236,72,153]  },
    { px:0.65,py:0.2,  r:0.38,col:[16,185,129]  },
  ];
  (function frame() {
    ctx.clearRect(0,0,c.width,c.height);
    orbs.forEach((o,i) => {
      const x = (o.px + Math.sin(t*0.25 + i*1.6) * 0.11) * c.width;
      const y = (o.py + Math.cos(t*0.18 + i*0.9) * 0.1) * c.height;
      const r = o.r * Math.max(c.width, c.height);
      const g = ctx.createRadialGradient(x,y,0,x,y,r);
      g.addColorStop(0,`rgba(${o.col},0.14)`);
      g.addColorStop(1,`rgba(${o.col},0)`);
      ctx.fillStyle = g; ctx.fillRect(0,0,c.width,c.height);
    });
    t += 0.008;
    requestAnimationFrame(frame);
  })();
}();

/* ── PARTICLE SYSTEM ─────────────────────────── */
!function() {
  const c = document.getElementById('p-canvas');
  const ctx = c.getContext('2d');
  let mouse = { x: -9999, y: -9999 };
  let particles = [];

  const resize = () => {
    c.width = c.offsetWidth; c.height = c.offsetHeight;
    init();
  };
  resize(); window.addEventListener('resize', resize);

  c.parentElement.addEventListener('mousemove', e => {
    const r = c.getBoundingClientRect();
    mouse.x = e.clientX - r.left; mouse.y = e.clientY - r.top;
  });
  c.parentElement.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });

  function init() {
    particles = [];
    const n = Math.min(120, Math.floor(c.width * c.height / 7000));
    for (let i = 0; i < n; i++) {
      particles.push({
        x: Math.random() * c.width,
        y: Math.random() * c.height,
        vx: (Math.random()-0.5)*0.6,
        vy: (Math.random()-0.5)*0.6,
        sz: Math.random()*1.8+0.5,
        hue: Math.random()*50+185,
      });
    }
  }

  (function frame() {
    ctx.clearRect(0,0,c.width,c.height);
    particles.forEach(p => {
      const dx = p.x-mouse.x, dy = p.y-mouse.y;
      const dist = Math.hypot(dx,dy);
      if (dist < 110) {
        const f = (110-dist)/110*2;
        p.vx += (dx/dist)*f*0.06;
        p.vy += (dy/dist)*f*0.06;
      }
      p.vx *= 0.988; p.vy *= 0.988;
      p.x += p.vx; p.y += p.vy;
      if (p.x < 0) p.x = c.width;
      if (p.x > c.width) p.x = 0;
      if (p.y < 0) p.y = c.height;
      if (p.y > c.height) p.y = 0;
      ctx.beginPath();
      ctx.arc(p.x,p.y,p.sz,0,Math.PI*2);
      ctx.fillStyle = `hsla(${p.hue},75%,70%,0.8)`;
      ctx.fill();
    });
    // Connections
    for (let i = 0; i < particles.length; i++) {
      for (let j = i+1; j < particles.length; j++) {
        const dx = particles[i].x-particles[j].x;
        const dy = particles[i].y-particles[j].y;
        const d = Math.hypot(dx,dy);
        if (d < 90) {
          ctx.beginPath();
          ctx.moveTo(particles[i].x,particles[i].y);
          ctx.lineTo(particles[j].x,particles[j].y);
          ctx.strokeStyle = `rgba(100,200,255,${(1-d/90)*0.28})`;
          ctx.lineWidth = 0.5; ctx.stroke();
        }
      }
    }
    requestAnimationFrame(frame);
  })();
}();

/* ── SCROLL REVEAL ───────────────────────────── */
!function() {
  const items = document.querySelectorAll('.reveal-item');
  const bars  = document.querySelectorAll('.prog-fill');

  new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.18 }).observe(document.getElementById('reveal-grid'));

  // Trigger all children when grid enters view
  const gridObs = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) items.forEach(el => el.classList.add('visible'));
  }, { threshold: 0.1 });
  gridObs.observe(document.getElementById('reveal-grid'));

  new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) bars.forEach(b => b.classList.add('animating'));
  }, { threshold: 0.5 }).observe(document.getElementById('prog-bars'));
}();

/* ── HOLOGRAPHIC CARDS ───────────────────────── */
!function() {
  document.querySelectorAll('.holo-card').forEach(card => {
    card.addEventListener('mousemove', e => {
      const r = card.getBoundingClientRect();
      const x = (e.clientX-r.left) / r.width  * 100;
      const y = (e.clientY-r.top)  / r.height * 100;
      card.style.setProperty('--mx', x+'%');
      card.style.setProperty('--my', y+'%');
      const rx = (y-50)/9, ry = (x-50)/9;
      card.style.transform = `perspective(650px) rotateX(${-rx}deg) rotateY(${ry}deg) scale(1.04)`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = '';
      card.style.setProperty('--mx','50%');
      card.style.setProperty('--my','50%');
    });
  });
}();
</script>
</body>
</html>
